# OpenTripPlanner base URL (OTP2 must be running locally or remotely)
NEXT_PUBLIC_OTP_URL=http://localhost:8080

# Photon geocoding base URL (self-hosted recommended, or use Komoot's public instance)
NEXT_PUBLIC_PHOTON_URL=https://photon.komoot.io

# WMATA API key — get one free at https://developer.wmata.com
# Used for Phase 2 live Metro arrivals (not required for Phase 1 routing)
WMATA_API_KEY=your_primary_key_here
